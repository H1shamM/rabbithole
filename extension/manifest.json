{
  "manifest_version": 3,
  "name": "Rabbithole",
  "version": "1.0",
  "description": "A serendipitous discovery engine.",
  "permissions": ["sidePanel", "tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Rabbithole"
  },
  "side_panel": {
    "default_path": "index.html"
  }
}
