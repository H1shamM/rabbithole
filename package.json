{
  "name": "stumble-clone",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "app/**/*.{js,ts}": ["eslint --fix", "bash -c \"cd app && npm run typecheck\""],
    "ui/**/*.{js,jsx,ts,tsx}": ["eslint --fix", "bash -c \"cd ui && npm run typecheck\""]
  }
}
