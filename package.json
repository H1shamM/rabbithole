{
  "name": "stumble-clone",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "eslint": "^10.4.1"
  },
  "lint-staged": {
    "app/**/*.{js,ts}": [
      "eslint --fix",
      "bash -c \"cd app && npm run typecheck\""
    ],
    "ui/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "bash -c \"cd ui && npm run typecheck\""
    ]
  }
}
