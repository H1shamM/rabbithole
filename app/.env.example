# StumbleClone Backend — Environment Variables
# Copy to .env and fill in real values before running.

# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=stumble.db

# Auth
# ⚠️  Change this to a long random secret in production!
JWT_SECRET=change-me-in-production

# Reader enrichment (optional) — the AI explainer feature (#184).
# When unset, /reader/enrich returns 422 and the UI falls back to the plain
# reader view (enrichment is additive, never required). Set this to enable it.
ANTHROPIC_API_KEY=

# Dev helpers (remove in production)
DEV_USER_ID=dev-user
